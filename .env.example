# Database
DATABASE_URL=postgresql+asyncpg://seo_agents:seo_agents@localhost:5432/seo_agents

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS_PER_DAY=500000

# Google Search Console
GSC_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GSC_SITE_URL=https://spioniro.ru

# Yandex Webmaster
YANDEX_WEBMASTER_TOKEN=your-token
YANDEX_WEBMASTER_USER_ID=your-user-id
YANDEX_WEBMASTER_HOST_ID=https:spioniro.ru:443

# Yandex.Metrica
YANDEX_METRICA_TOKEN=your-token
YANDEX_METRICA_COUNTER_ID=your-counter-id

# Yandex XML / XMLRiver (Wordstat + SERP)
XMLRIVER_USER=your-user
XMLRIVER_KEY=your-key

# IndexNow
INDEXNOW_KEY=your-indexnow-key

# spioniro.ru API (AI mentions analytics)
SPIONIRO_API_URL=https://api.spioniro.ru
SPIONIRO_API_KEY=your-api-key

# Target site
TARGET_SITE_URL=https://spioniro.ru
TARGET_SITE_NAME=Spioniro

# Goals
GOAL_MONTHLY_VISITORS=10000
GOAL_MONTHLY_REGISTRATIONS=500
